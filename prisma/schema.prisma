generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  realName  String
  title     String?
  phone     String?
  email     String?
  role      String   @default("DOCTOR")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  patients      Patient[]
  followupPlans FollowupPlan[]
  followupRecords FollowupRecord[]
}

model DiseaseType {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  code        String   @unique
  description String?
  normalRange Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  patients Patient[]
}

model Patient {
  id           Int        @id @default(autoincrement())
  name         String
  gender       String
  birthDate    DateTime
  idCard       String     @unique
  phone        String
  address      String?
  bloodType    String?
  height       Float?
  weight       Float?
  allergies    String?
  medicalHistory String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  doctorId     Int
  diseaseTypeId Int

  doctor       User            @relation(fields: [doctorId], references: [id])
  diseaseType  DiseaseType     @relation(fields: [diseaseTypeId], references: [id])
  healthRecords HealthRecord[]
  followupPlans FollowupPlan[]
  followupRecords FollowupRecord[]
  alerts       Alert[]
}

model FollowupPlan {
  id          Int       @id @default(autoincrement())
  patientId   Int
  doctorId    Int
  planDate    DateTime
  status      String    @default("PENDING")
  frequency   String?
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  patient        Patient          @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctor         User             @relation(fields: [doctorId], references: [id])
  followupRecords FollowupRecord[]
}

model HealthRecord {
  id          Int      @id @default(autoincrement())
  patientId   Int
  recordDate  DateTime
  systolic    Float?
  diastolic   Float?
  heartRate   Int?
  fastingGlucose Float?
  postprandialGlucose Float?
  cholesterol Float?
  triglycerides Float?
  weight      Float?
  note        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
  alerts  Alert[]
}

model FollowupRecord {
  id          Int       @id @default(autoincrement())
  patientId   Int
  doctorId    Int
  planId      Int?
  visitDate   DateTime
  chiefComplaint String?
  examination  String?
  diagnosis    String?
  treatment    String?
  medication   String?
  advice       String?
  nextVisitDate DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  patient Patient       @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctor  User          @relation(fields: [doctorId], references: [id])
  plan    FollowupPlan? @relation(fields: [planId], references: [id], onDelete: SetNull)
}

model Alert {
  id          Int      @id @default(autoincrement())
  patientId   Int
  recordId    Int?
  alertType   String
  severity    String
  message     String
  indicator   String?
  value       Float?
  isRead      Boolean  @default(false)
  resolved    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  patient       Patient       @relation(fields: [patientId], references: [id], onDelete: Cascade)
  healthRecord  HealthRecord? @relation(fields: [recordId], references: [id], onDelete: SetNull)
}
